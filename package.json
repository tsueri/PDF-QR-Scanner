{
  "name": "pdf-qr-scanner",
  "version": "1.2.0",
  "description": "Scan QR Codes in PDF and get it back as CSV.",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "test": "node test-regression.cjs && node test-csv.mjs && node test-zip.mjs",
    "test:integration": "node test-integration.cjs",
    "build:css": "sass --no-source-map --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --silence-deprecation=if-function scss/custom.scss scss/custom.css"
  },
  "keywords": [
    "pdf",
    "qr",
    "code",
    "scan"
  ],
  "author": "Jonas Zürcher",
  "license": "MIT",
  "dependencies": {
    "bootstrap": "^5.3.8",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "pdfkit": "^0.19.1",
    "puppeteer": "^25.3.0",
    "qrcode": "^1.5.4"
  }
}
